<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.labjournal.androidlab"
    android:versionCode="1"
    android:versionName="1.0" >

    <uses-sdk
        android:minSdkVersion="24"
        android:targetSdkVersion="34" />

    <permission
        android:name="com.labjournal.androidlab.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION"
        android:protectionLevel="signature" />

    <uses-permission android:name="com.labjournal.androidlab.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION" />

    <application
        android:allowBackup="true"
        android:appComponentFactory="androidx.core.app.CoreComponentFactory"
        android:debuggable="true"
        android:extractNativeLibs="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:testOnly="true"
        android:theme="@style/Theme.AndroidLabJournal" >

        <!-- Exercise 6: Main Dashboard / Home Activity -->
        <activity
            android:name="com.labjournal.androidlab.MainActivity"
            android:exported="true"
            android:label="@string/app_name" >
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Exercise 6: Hello World Activity -->
        <activity
            android:name="com.labjournal.androidlab.HelloWorldActivity"
            android:label="Hello World"
            android:parentActivityName="com.labjournal.androidlab.MainActivity" />

        <!-- Exercise 5: Lifecycle Demo Activity -->
        <activity
            android:name="com.labjournal.androidlab.LifecycleActivity"
            android:label="Lifecycle Demo"
            android:parentActivityName="com.labjournal.androidlab.MainActivity" />

        <!-- Exercise 7: Linear Layout with Image and Buttons -->
        <activity
            android:name="com.labjournal.androidlab.LinearLayoutActivity"
            android:label="Linear Layout Demo"
            android:parentActivityName="com.labjournal.androidlab.MainActivity" />

        <!-- Exercise 8: Form with Input Fields -->
        <activity
            android:name="com.labjournal.androidlab.FormActivity"
            android:label="Form Demo"
            android:parentActivityName="com.labjournal.androidlab.MainActivity" />

        <!-- Exercise 9: Different Layouts Demo -->
        <activity
            android:name="com.labjournal.androidlab.LayoutDemoActivity"
            android:label="Layout Demo"
            android:parentActivityName="com.labjournal.androidlab.MainActivity" />

        <!-- Exercise 10: Simple Calculator -->
        <activity
            android:name="com.labjournal.androidlab.CalculatorActivity"
            android:label="Calculator"
            android:parentActivityName="com.labjournal.androidlab.MainActivity" />

        <!-- Exercise 11: Toggle Button -->
        <activity
            android:name="com.labjournal.androidlab.ToggleButtonActivity"
            android:label="Toggle Button Demo"
            android:parentActivityName="com.labjournal.androidlab.MainActivity" />

        <!-- Exercise 12: Database Storage -->
        <activity
            android:name="com.labjournal.androidlab.DatabaseActivity"
            android:label="Database Demo"
            android:parentActivityName="com.labjournal.androidlab.MainActivity" />

        <!-- Exercise 13: Udemy Registration Form -->
        <activity
            android:name="com.labjournal.androidlab.UdemyRegActivity"
            android:label="Udemy Registration"
            android:parentActivityName="com.labjournal.androidlab.MainActivity" />

        <!-- Basic Widget Demo -->
        <activity
            android:name="com.labjournal.androidlab.BasicWidgetActivity"
            android:label="Basic Widgets"
            android:parentActivityName="com.labjournal.androidlab.MainActivity" />

        <!-- Internal Framework -->
        <activity
            android:name="com.labjournal.androidlab.InternalFrameworkActivity"
            android:label="Internal Framework"
            android:parentActivityName="com.labjournal.androidlab.MainActivity" />

        <!-- Final Projects -->
        <activity
            android:name="com.labjournal.androidlab.TaskManagerActivity"
            android:label="Task Manager"
            android:parentActivityName="com.labjournal.androidlab.MainActivity" />
        <activity
            android:name="com.labjournal.androidlab.GpaTrackerActivity"
            android:label="GPA Tracker"
            android:parentActivityName="com.labjournal.androidlab.MainActivity" />
        <activity
            android:name="com.labjournal.androidlab.ContactBookActivity"
            android:label="Contact Book"
            android:parentActivityName="com.labjournal.androidlab.MainActivity" />
        <activity
            android:name="com.labjournal.androidlab.ScientificCalculatorActivity"
            android:label="Scientific Calculator"
            android:parentActivityName="com.labjournal.androidlab.MainActivity" />

        <!-- E-Commerce Modules -->
        <activity
            android:name="com.labjournal.androidlab.StoreWelcomeActivity"
            android:label="Store"
            android:parentActivityName="com.labjournal.androidlab.MainActivity" />
        <activity
            android:name="com.labjournal.androidlab.StoreHubActivity"
            android:label="Store Hub"
            android:parentActivityName="com.labjournal.androidlab.StoreWelcomeActivity" />
        <activity
            android:name="com.labjournal.androidlab.CatalogActivity"
            android:label="Catalog"
            android:parentActivityName="com.labjournal.androidlab.StoreHubActivity" />
        <activity
            android:name="com.labjournal.androidlab.ProductDetailActivity"
            android:label="Product Detail"
            android:parentActivityName="com.labjournal.androidlab.CatalogActivity" />
        <activity
            android:name="com.labjournal.androidlab.FavoritesActivity"
            android:label="Favorites"
            android:parentActivityName="com.labjournal.androidlab.StoreHubActivity" />
        <activity
            android:name="com.labjournal.androidlab.CartActivity"
            android:label="Shopping Cart"
            android:parentActivityName="com.labjournal.androidlab.StoreHubActivity" />
        <activity
            android:name="com.labjournal.androidlab.CheckoutActivity"
            android:label="Checkout"
            android:parentActivityName="com.labjournal.androidlab.CartActivity" />
        <activity
            android:name="com.labjournal.androidlab.OrderTrackingActivity"
            android:label="Order Tracking"
            android:parentActivityName="com.labjournal.androidlab.StoreHubActivity" />
        <activity
            android:name="com.labjournal.androidlab.OrderHistoryActivity"
            android:label="Order History"
            android:parentActivityName="com.labjournal.androidlab.StoreHubActivity" />

        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="com.labjournal.androidlab.androidx-startup"
            android:exported="false" >
            <meta-data
                android:name="androidx.emoji2.text.EmojiCompatInitializer"
                android:value="androidx.startup" />
            <meta-data
                android:name="androidx.lifecycle.ProcessLifecycleInitializer"
                android:value="androidx.startup" />
            <meta-data
                android:name="androidx.profileinstaller.ProfileInstallerInitializer"
                android:value="androidx.startup" />
        </provider>

        <receiver
            android:name="androidx.profileinstaller.ProfileInstallReceiver"
            android:directBootAware="false"
            android:enabled="true"
            android:exported="true"
            android:permission="android.permission.DUMP" >
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.INSTALL_PROFILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.SKIP_FILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.SAVE_PROFILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.BENCHMARK_OPERATION" />
            </intent-filter>
        </receiver>
    </application>

</manifest>