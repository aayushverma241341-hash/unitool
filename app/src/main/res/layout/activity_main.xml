<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_main.xml - Android Lab Journal Dashboard
    =================================================
    This is the main dashboard/home screen for the Lab Journal app.
    It displays a premium-looking header with the app title, followed by
    a scrollable grid of 8 exercise cards arranged in 2 columns.

    Layout Structure:
    - LinearLayout (root, vertical)
      ├── Header area with gradient background (@drawable/gradient_header)
      │   ├── App Title: "Android Lab Journal"
      │   └── Subtitle: "Lab Exercises Dashboard"
      └── ScrollView
          └── GridLayout (2 columns)
              ├── Card: Ex 5 - Lifecycle Demo
              ├── Card: Ex 6 - Hello World
              ├── Card: Ex 7 - Linear Layout
              ├── Card: Ex 8 - Form Inputs
              ├── Card: Ex 9 - Layout Types
              ├── Card: Ex 10 - Calculator
              ├── Card: Ex 11 - Toggle Button
              └── Card: Ex 12 - Database

    Each card uses a MaterialCardView with:
    - 16dp corner radius for modern rounded look
    - 6dp elevation for shadow/depth effect
    - Emoji icon rendered as large text
    - Exercise number and description
    - Unique tinted background color
    - Unique ID for click handling (card_ex5, card_ex6, etc.)
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5"
    tools:context=".MainActivity">

    <!-- ============================================================
         HEADER SECTION
         A visually rich header area with a gradient background.
         Contains the app title and a descriptive subtitle.
         The gradient drawable is defined in @drawable/gradient_header.
         ============================================================ -->
    <RelativeLayout
        android:id="@+id/header_area"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/gradient_header"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="48dp"
        android:paddingBottom="32dp">

        <!-- App Title - Large, bold, white text for maximum impact -->
        <TextView
            android:id="@+id/tv_app_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎓 UniToolkit"
            android:textSize="28sp"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:layout_alignParentStart="true" />

        <!-- Subtitle - Smaller, semi-transparent white text below the title -->
        <TextView
            android:id="@+id/tv_app_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/tv_app_title"
            android:layout_marginTop="6dp"
            android:text="Lab Exercises Dashboard"
            android:textSize="16sp"
            android:textColor="#B3FFFFFF"
            android:fontFamily="sans-serif-light" />

    </RelativeLayout>

    <!-- ============================================================
         SCROLLABLE CARD GRID
         A ScrollView wrapping a GridLayout with 2 columns.
         Each cell contains a CardView representing one lab exercise.
         The ScrollView ensures all cards are accessible on any screen size.
         ============================================================ -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingBottom="16dp">

        <GridLayout
            android:id="@+id/grid_exercises"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:rowCount="5"
            android:padding="12dp"
            android:useDefaultMargins="false"
            android:alignmentMode="alignBounds">

            <!-- ====================================================
                 CARD 1: Exercise 5 - Lifecycle Demo
                 Demonstrates the Android Activity Lifecycle callbacks
                 (onCreate, onStart, onResume, onPause, onStop, onDestroy).
                 Icon: 🔄 (recycling arrows, representing the lifecycle loop)
                 ==================================================== -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_ex5"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="6dp"
                android:layout_columnWeight="1"
                android:layout_rowWeight="1"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="@color/card_lifecycle">

                <!-- Card inner content: emoji icon, exercise number, description -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:gravity="center">

                    <!-- Large emoji icon for visual identification -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔄"
                        android:textSize="40sp"
                        android:layout_marginBottom="12dp" />

                    <!-- Exercise number label -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Exercise 5"
                        android:textSize="13sp"
                        android:textColor="#90FFFFFF"
                        android:fontFamily="sans-serif-medium"
                        android:textAllCaps="true"
                        android:letterSpacing="0.05" />

                    <!-- Exercise description -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lifecycle Demo"
                        android:textSize="16sp"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp"
                        android:gravity="center" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ====================================================
                 CARD 2: Exercise 6 - Hello World
                 The classic first Android app that displays "Hello World!"
                 Icon: 👋 (waving hand, welcoming gesture)
                 ==================================================== -->
