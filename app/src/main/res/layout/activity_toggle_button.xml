<?xml version="1.0" encoding="utf-8"?>
<!--
    ============================================================================
    activity_toggle_button.xml — Exercise 11: Toggle Button Demo
    ============================================================================
    This layout demonstrates two types of on/off controls in Android:

    1. ToggleButton — The classic two-state button (textOn / textOff).
    2. Switch / SwitchCompat — A modern sliding toggle, commonly used in
       settings screens.

    Both extend CompoundButton, so they share the same listener interface:
        CompoundButton.OnCheckedChangeListener

    Layout hierarchy:
        LinearLayout (root, vertical)
          └─ Toolbar
          └─ ScrollView
               └─ LinearLayout (content, vertical)
                    ├─ CardView  →  Basic ToggleButton + status
                    ├─ CardView  →  Wi-Fi Switch + status
                    ├─ CardView  →  Bluetooth Switch + status
                    ├─ CardView  →  Notifications Switch + status
                    ├─ CardView  →  Dark Mode Switch + status
                    ├─ CardView  →  Visual Indicator (color changes)
                    └─ CardView  →  Summary of all states
    ============================================================================
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF"
    tools:context=".ToggleButtonActivity">

    <!-- ================================================================
         Toolbar — provides a consistent top bar with back navigation
         ================================================================ -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/colorPrimary"
        android:elevation="4dp"
        app:title="Toggle Button Demo"
        app:titleTextColor="#FFFFFF"
        app:navigationIcon="?attr/homeAsUpIndicator" />

    <!-- ================================================================
         ScrollView — makes the entire content scrollable on small screens
         ================================================================ -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/content_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ────────────────────────────────────────────────────────
                 Section Header: Toggle Buttons
                 ──────────────────────────────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Toggle Controls"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginBottom="12dp" />

            <!-- ========================================================
                 CARD 1: Basic ToggleButton
                 ========================================================
                 ToggleButton is the original Android on/off widget.
                 It displays textOn when checked, textOff when unchecked.
                 ======================================================== -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                app:cardUseCompatPadding="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Label for this section -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Basic ToggleButton"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#555555"
                        android:layout_marginBottom="8dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <!--
                            ToggleButton — classic two-state button.
                            textOn:  Text shown when checked (true)
                            textOff: Text shown when unchecked (false)
                        -->
                        <ToggleButton
                            android:id="@+id/toggle_basic"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textOn="ON"
                            android:textOff="OFF"
                            android:minWidth="100dp"
                            android:layout_marginEnd="16dp" />

                        <!-- Status text — updated programmatically -->
                        <TextView
                            android:id="@+id/tv_toggle_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Toggle is OFF"
                            android:textSize="15sp"
                            android:textColor="#777777" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ========================================================
                 CARD 2: Wi-Fi Switch
                 ========================================================
                 Switch (or SwitchCompat) is the modern sliding toggle.
                 It's the preferred widget for settings-style screens.
                 ======================================================== -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                app:cardUseCompatPadding="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <!-- Wi-Fi icon placeholder (emoji in text) -->
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="📶  Wi-Fi"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#555555" />

                        <!-- SwitchCompat — backwards-compatible Switch widget -->
                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/switch_wifi"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>

                    <!-- Status text for Wi-Fi -->
                    <TextView
                        android:id="@+id/tv_wifi_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Wi-Fi is OFF"
                        android:textSize="13sp"
                        android:textColor="#999999"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ========================================================
                 CARD 3: Bluetooth Switch
                 ======================================================== -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                app:cardUseCompatPadding="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="🔵  Bluetooth"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#555555" />

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/switch_bluetooth"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_bluetooth_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bluetooth is OFF"
                        android:textSize="13sp"
                        android:textColor="#999999"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ========================================================
                 CARD 4: Notifications Switch
                 ======================================================== -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                app:cardUseCompatPadding="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="🔔  Notifications"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#555555" />

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/switch_notification"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_notification_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Notifications are OFF"
                        android:textSize="13sp"
                        android:textColor="#999999"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ========================================================
                 CARD 5: Dark Mode Switch
                 ========================================================
                 This switch demonstrates changing the UI theme dynamically.
                 When toggled, the root layout background and text colors
                 will change to simulate dark mode.
                 ======================================================== -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                app:cardUseCompatPadding="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="🌙  Dark Mode"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#555555" />

                        <!-- Using standard Switch for variety (also a CompoundButton) -->
                        <Switch
                            android:id="@+id/switch_dark_mode"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_darkmode_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dark Mode is OFF"
                        android:textSize="13sp"
                        android:textColor="#999999"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ────────────────────────────────────────────────────────
                 Divider
                 ──────────────────────────────────────────────────────── -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                android:layout_marginBottom="16dp" />

            <!-- ========================================================
                 Visual Indicator Area
                 ========================================================
                 This View changes color based on the basic ToggleButton:
                   • Green (#4CAF50) when ON
                   • Red   (#F44336) when OFF
                 Demonstrates how toggle state can drive UI changes.
                 ======================================================== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Visual Indicator"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#555555"
                android:layout_marginBottom="8dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardUseCompatPadding="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="8dp">

                    <!--
                        view_indicator — A large colored rectangle.
                        Starts red (OFF state). Java code toggles between
                        green and red based on toggle_basic's state.
                    -->
                    <View
                        android:id="@+id/view_indicator"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:background="#F44336" />

                    <TextView
                        android:id="@+id/tv_indicator_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Status: OFF"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#777777"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="4dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ────────────────────────────────────────────────────────
                 Divider
                 ──────────────────────────────────────────────────────── -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                android:layout_marginBottom="16dp" />

            <!-- ========================================================
                 Summary Section
                 ========================================================
                 Displays all current toggle/switch states in one place.
                 Updated every time any toggle changes.
                 ======================================================== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Summary of All States"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#555555"
                android:layout_marginBottom="8dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#F5F5F5"
                app:cardUseCompatPadding="true">

                <TextView
                    android:id="@+id/tv_summary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:text="Toggle: OFF\nWi-Fi: OFF\nBluetooth: OFF\nNotifications: OFF\nDark Mode: OFF"
                    android:textSize="14sp"
                    android:textColor="#555555"
                    android:lineSpacingExtra="6dp"
                    android:fontFamily="monospace" />
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
